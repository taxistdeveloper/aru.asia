RewriteEngine On

# При ошибках сервера и техработах показываем страницу «Идут технические работы»
# Работает даже когда PHP или приложение недоступны (путь относительно папки с .htaccess)
ErrorDocument 500 maintenance.html
ErrorDocument 502 maintenance.html

ErrorDocument 503 maintenance.html

# Лимиты загрузки (Apache + mod_php). Не действуют при PHP-FPM/CGI — см. app/config/config.php.
# Если после добавления этих строк появляется 500 — удалите их и настройте php.ini или .user.ini.
# ЗАКОММЕНТИРОВАНО: Эти директивы не работают с PHP-FPM/CGI (типично для MAMP)
# Настройте лимиты в php.ini: /Applications/MAMP/bin/php/phpX.X.X/conf/php.ini
# php_value upload_max_filesize 20M
# php_value post_max_size 25M
# php_value max_execution_time 120

# Никогда не переписываем статику (картинки, css, js и т.п.)
RewriteRule ^uploads/ - [L,NC]
RewriteRule ^assets/ - [L,NC]

# Любой существующий файл/папку отдаём напрямую Apache
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Остальные запросы направляем во фронт-контроллер
RewriteRule ^ index.php [QSA,L]
